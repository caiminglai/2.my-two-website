# ===== 精准匹配 - 环境变量配置模板 =====
# 复制此文件为 .env 并填写实际值

# 服务端口
PORT=8080

# API 路径前缀(前端访问后端的路径前缀)
API_PREFIX=/jzxr

# 前端地址(用于 CORS 白名单,多个用逗号分隔)
FRONTEND_URL=http://localhost:4000,http://localhost:4001

# 服务端地址(用于 CORS,生产环境填服务器IP或域名)
SERVER_ORIGIN=http://localhost:8080

# 管理员密码(设置后将优先使用;不设置则从数据库读取)
ADMIN_PASSWORD=your-admin-password-here

# 管理员账号白名单(多个用逗号分隔,未设置则默认允许admin登录)
ADMIN_USERNAME=admin

# AES-256 加密密钥(32字节十六进制字符串,迁移数据前请勿修改)
ENCRYPTION_KEY=your-32-byte-hex-key-here

# PostgreSQL 数据库配置
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=match_db
PG_PASSWORD=your-postgres-password-here

# Embedding API 配置(可选,用于生成用户画像向量)
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=your-openai-api-key-here
EMBEDDING_MODEL=text-embedding-ada-002
