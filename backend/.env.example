# ===== 精准匹配 - 环境变量配置 =====
# 复制此文件为 .env 并填入实际值

# 服务端口
PORT=8080

# API 路径前缀
API_PREFIX=/jzxr

# 前端地址（用于 CORS 白名单）
FRONTEND_URL=http://localhost:4000

# 服务端地址（用于 CORS）
SERVER_ORIGIN=http://your_server_ip

# 管理员密码（必填，不能为空）
ADMIN_PASSWORD=your_secure_password_here

# AES-256 加密密钥（请使用强随机字符串）
ENCRYPTION_KEY=your_aes_256_encryption_key_here

# 短信服务配置（预留）
# SMS_ACCESS_KEY_ID=
# SMS_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=

# 支付配置（预留）
# WECHAT_APP_ID=
# WECHAT_MCH_ID=
# WECHAT_API_KEY=
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
